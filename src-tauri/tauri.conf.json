{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "ClipFlow",
  "version": "1.0.0-beta",
  "identifier": "com.clipflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ClipFlow - AI 视频创作平台",
        "width": 1200,
        "height": 800,
        "center": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../dist": "dist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "dialog": {},
    "fs": {
      "scope": {
        "allow": ["$APP/**", "$DOCUMENT/**", "$DOWNLOAD/**", "$HOME/**", "**"]
      }
    },
    "shell": {
      "open": true
    }
  }
}
