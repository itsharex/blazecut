# API 配置
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# AI 模型
VITE_DEFAULT_MODEL=gpt-4
VITE_OPENAI_API_KEY=
VITE_OPENAI_ENDPOINT=https://api.openai.com/v1
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_ENDPOINT=https://api.anthropic.com

# 视频处理
VITE_MAX_VIDEO_SIZE=500
VITE_DEFAULT_EXPORT_FORMAT=mp4

# 缓存
VITE_CACHE_ENABLED=true
VITE_CACHE_MAX_SIZE=500
VITE_CACHE_TTL=3600000

# 性能
VITE_ENABLE_HW_ACCEL=true
VITE_WORKER_THREADS=4

# 日志
VITE_LOG_LEVEL=info
VITE_ENABLE_REMOTE_LOGGING=false
